# ===========================================================================
# Long-Tail Arbitrage Engine — VPS environment template
# Copy to .env and fill in real values before deploying.
#   cp .env.example .env && nano .env
# ===========================================================================

# --- Execution mode -------------------------------------------------------
# true  = PAPER (simulate + on-chain quote, never broadcast)
# false = LIVE (sign + broadcast flashloan via keystore)
DRY_RUN=true

# --- RPC transport --------------------------------------------------------
# HTTP polling is used when WSS_RPC_URL is empty (default, per directive:
# we stay on HTTP due to WSS paywalls). Set a real wss:// endpoint to use
# the WebSocket listener instead. sync_transport: auto|wss|http
SYNC_TRANSPORT=auto
WSS_RPC_URL=
ANKR_API_KEY=
# Optional explicit primary RPC (overrides Ankr derivation). HTTP/2 endpoint.
ANKR_RPC_URL=
# Fallback public RPC used when primary fails.
FALLBACK_RPC_URL=https://arb1.arbitrum.io/rpc
# Private mempool relay for broadcasting (bypass public mempool sandwiches).
FLASHBOTS_RPC_URL=https://rpc.flashbots.net/fast
# Simultaneous broadcast (shotgun) endpoints for eth_sendRawTransaction.
# The signed tx is fired to ALL of these concurrently; the first to reach
# Arbitrum's FCFS sequencer wins. Comma-separated. Recommended baseline:
# Ankr (keyed) + Ankr (keyless public) + dRPC for path diversity.
# Example:
# EXECUTION_RPCS=https://rpc.ankr.com/arbitrum/<ANKR_API_KEY>,https://rpc.ankr.com/arbitrum,https://arbitrum.drpc.org
EXECUTION_RPCS=

# --- Polling tuning (LogsPoller, HTTP transport) --------------------------
SYNC_POLL_INTERVAL=1.5
SYNC_POLL_BLOCKS=5
SYNC_LOOKBACK_BLOCKS=50
RPC_RATE_LIMIT_PER_SEC=10

# --- Capital model --------------------------------------------------------
# Flashloan capital is UNCAPPED. The engine sizes each trade via an on-chain
# grid search (QuoterV2 + Multicall3) and executes only when
# net_profit_wei > estimated_gas_cost_wei. No TRADE_SIZE_USD / MIN_SPREAD_PCT
# knobs — leave these unset; they only affect the legacy triangular path.
# TRADE_SIZE_USD=10
# MIN_SPREAD_PCT=0.5
GAS_BASELINE_USD=0.02
MIN_NET_PROFIT_USD=0.50
MIN_LIQUIDITY_USD=100.0
MAX_LIQUIDITY_USD=100000.0

# --- Wallet / executor (LIVE mode only) -----------------------------------
KEYSTORE_PATH=./keystore.json
KEYSTORE_PASSPHRASE=
# Set after deploying the executor: python scripts/deploy_executor.py
FLASHLOAN_EXECUTOR_ADDRESS=
BALANCER_VAULT_ADDRESS=0xBA12222222228d8Ba445958a75a0704d566BF2C8

# --- LLM security auditor (honeypot/scam detection) -----------------------
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL_PRIMARY=llama-3.3-70b-versatile
LLM_MODEL_FALLBACK=gemma2-9b-it
LLM_MAX_RETRIES=5
LLM_TEMPERATURE=0.0

# --- Token / contract discovery sources -----------------------------------
ARBISCAN_API_KEY=
# (ETHERSCAN_API_KEY / SSLKEYLOGFILE are read by some helper scripts; optional)

# --- Whitelist seeding (scripts/seed_whitelist.py) ------------------------
WHITELIST_PATH=config/whitelist.json
TARGET_POOLS=500
SEED_PAGES=25

# --- Monitoring / alerts --------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
PROMETHEUS_PORT=9090
LOG_LEVEL=INFO

# --- Misc -----------------------------------------------------------------
DB_PATH=longtail.db
MAX_CONCURRENT_GRAPHS=5
DEXSCREENER_RATE_LIMIT=3.0
SCANNER_SCAN_INTERVAL=30
CACHE_TTL_HOURS=24
